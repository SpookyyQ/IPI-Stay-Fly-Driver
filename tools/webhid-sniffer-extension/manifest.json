{
  "manifest_version": 3,
  "name": "Mouse WebHID Sniffer",
  "version": "0.2.0",
  "description": "Logs WebHID reports for reverse engineering mouse web drivers.",
  "content_scripts": [
    {
      "matches": [
        "https://qbz.ipigame.cn/*",
        "http://qbz.ipigame.cn/*",
        "https://hub.atk.pro/*",
        "http://hub.atk.pro/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pageHook.js"
      ],
      "matches": [
        "https://qbz.ipigame.cn/*",
        "http://qbz.ipigame.cn/*",
        "https://hub.atk.pro/*",
        "http://hub.atk.pro/*"
      ]
    }
  ]
}
